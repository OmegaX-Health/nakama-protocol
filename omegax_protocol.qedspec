/// `attach_claim_evidence_ref` - Anchor facade forwarder.
/// Implementation: `crate::claims::attach_claim_evidence_ref`; accounts context: `AttachClaimEvidenceRef`.
/// `adjudicate_claim_case` - Anchor facade forwarder.
/// Implementation: `crate::claims::adjudicate_claim_case`; accounts context: `AdjudicateClaimCase`.
handler adjudicate_claim_case (args : AdjudicateClaimCaseArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority           : signer
    protocol_governance : readonly
    health_plan         : readonly
    claim_case          : writable
    obligation          : writable
  }

  requires emergency_pause == false else ProtocolEmergencyPaused
  requires args.reserve_amount <= args.approved_amount else AmountExceedsApprovedClaim

  // SPEC-REFINE: replace abstract deltas with exact account-field RHS where needed.
  effect {
    review_state := args.review_state
    approved_amount := args.approved_amount
    denied_amount := args.denied_amount
    audit_nonce +=! 1
  }
}

/// `settle_claim_case` - Anchor facade forwarder.
/// Implementation: `crate::claims::settle_claim_case`; accounts context: `SettleClaimCase`.
handler settle_claim_case (args : SettleClaimCaseArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority               : signer
    protocol_governance     : readonly
    health_plan             : readonly
    reserve_asset_rail      : readonly
    domain_asset_vault      : writable
    domain_asset_ledger     : writable
    funding_line            : writable
    funding_line_ledger     : writable
    plan_reserve_ledger     : writable
    series_reserve_ledger   : writable
    pool_class_ledger       : writable
    allocation_position     : writable
    allocation_ledger       : writable
    claim_case              : writable
    obligation              : writable
    protocol_fee_vault      : writable
    pool_oracle_fee_vault   : writable
    pool_oracle_policy      : readonly
    oracle_fee_attestation  : readonly
    member_position         : readonly
    asset_mint              : readonly
    vault_token_account     : writable
    recipient_token_account : writable
    token_program           : program
  }

  requires emergency_pause == false else ProtocolEmergencyPaused
  requires args.amount > 0 else AmountMustBePositive
  requires paid_amount + args.amount <= approved_amount else AmountExceedsApprovedClaim
  requires args.rail_active == true else ReserveAssetRailInactive
  requires args.rail_payout_enabled == true else ReserveAssetRailPayoutDisabled
  requires args.rail_price_usd_1e8 > 0 else ReserveAssetPriceInvalid
  requires args.rail_max_staleness_seconds > 0 else ReserveAssetPriceInvalid
  requires args.rail_max_confidence_bps > 0 else ReserveAssetPriceInvalid
  requires args.rail_last_price_confidence_bps <= args.rail_max_confidence_bps else ReserveAssetPriceConfidenceTooWide
  requires args.rail_last_price_published_at_ts > 0 else ReserveAssetPriceStale

  // SPEC-CPI: direct claim settlement pays net recipient amount after protocol/oracle fees.
  transfers {
    from vault_token_account to recipient_token_account amount claim_net_payout_amount authority domain_asset_vault
  }

  // SPEC-REFINE: bind payment RHS to remaining approved claim and fee-vault deltas.
  effect {
    paid_amount +=! 1
    reserved_amount +=! 1
    updated_at +=! 1
    audit_nonce +=! 1
  }
}

