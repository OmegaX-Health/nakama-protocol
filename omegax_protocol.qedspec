/// `settle_obligation` - Anchor facade forwarder.
/// Implementation: `crate::funding_obligations::settle_obligation`; accounts context: `SettleObligation`.
handler settle_obligation (args : SettleObligationArgs) : State.Live -> State.Live {
  auth authority

  accounts {
    authority               : signer
    protocol_governance     : readonly
    health_plan             : readonly
    reserve_asset_rail      : readonly
    domain_asset_vault      : writable
    domain_asset_ledger     : writable
    funding_line            : writable
    funding_line_ledger     : writable
    plan_reserve_ledger     : writable
    series_reserve_ledger   : writable
    pool_class_ledger       : writable
    allocation_position     : writable
    allocation_ledger       : writable
    obligation              : writable
    claim_case              : writable
    member_position         : readonly
    asset_mint              : readonly
    vault_token_account     : writable
    recipient_token_account : writable
    token_program           : program
    pool_oracle_fee_vault   : writable
    pool_oracle_policy      : readonly
    oracle_fee_attestation  : readonly
  }

  requires emergency_pause == false else ProtocolEmergencyPaused
  requires args.amount > 0 else AmountMustBePositive
  requires args.rail_active == true else ReserveAssetRailInactive
  requires args.rail_payout_enabled == true else ReserveAssetRailPayoutDisabled
  requires args.rail_price_usd_1e8 > 0 else ReserveAssetPriceInvalid
  requires args.rail_max_staleness_seconds > 0 else ReserveAssetPriceInvalid
  requires args.rail_max_confidence_bps > 0 else ReserveAssetPriceInvalid
  requires args.rail_last_price_confidence_bps <= args.rail_max_confidence_bps else ReserveAssetPriceConfidenceTooWide
  requires args.rail_last_price_published_at_ts > 0 else ReserveAssetPriceStale

  // SPEC-CPI: settled obligations pay the net recipient amount after oracle fees.
  transfers {
    from vault_token_account to recipient_token_account amount settlement_net_payout_amount authority domain_asset_vault
  }

  // SPEC-REFINE: replace abstract deltas with exact account-field RHS where needed.
  effect {
    reserved_amount +=! 1
    updated_at +=! 1
    audit_nonce +=! 1
  }
}

